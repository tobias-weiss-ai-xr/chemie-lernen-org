{
  "budgets": [
    {
      "path": "./myhugoapp/static/js/calculators/**/*.js",
      "type": "javascript",
      "maxSize": "50 KB",
      "gzip": true,
      "description": "Calculator JavaScript files"
    },
    {
      "path": "./myhugoapp/static/js/**/*.js",
      "type": "javascript",
      "maxSize": "200 KB",
      "gzip": true,
      "description": "Individual JavaScript files"
    },
    {
      "path": "./myhugoapp/static/css/**/*.css",
      "type": "stylesheet",
      "maxSize": "50 KB",
      "gzip": true,
      "description": "CSS files"
    },
    {
      "path": "./myhugoapp/public/**/*.html",
      "type": "document",
      "maxSize": "50 KB",
      "gzip": true,
      "description": "HTML pages"
    },
    {
      "path": "./myhugoapp/static/images/**/*.{png,jpg,jpeg,gif,svg}",
      "type": "image",
      "maxSize": "500 KB",
      "description": "Image files"
    },
    {
      "path": "./myhugoapp/public/stoechiometrie-rechner/**",
      "type": "total",
      "maxSize": "300 KB",
      "gzip": true,
      "description": "Total calculator page size"
    }
  ],
  "thresholds": {
    "performance": [
      {
        "metric": "first-contentful-paint",
        "budget": 2000,
        "unit": "ms",
        "description": "First Contentful Paint should be under 2 seconds"
      },
      {
        "metric": "largest-contentful-paint",
        "budget": 2500,
        "unit": "ms",
        "description": "Largest Contentful Paint should be under 2.5 seconds"
      },
      {
        "metric": "cumulative-layout-shift",
        "budget": 0.1,
        "unit": "score",
        "description": "Cumulative Layout Shift should be under 0.1"
      },
      {
        "metric": "total-blocking-time",
        "budget": 300,
        "unit": "ms",
        "description": "Total Blocking Time should be under 300ms"
      },
      {
        "metric": "speed-index",
        "budget": 3400,
        "unit": "ms",
        "description": "Speed Index should be under 3.4 seconds"
      }
    ],
    "accessibility": [
      {
        "metric": "contrast",
        "budget": 90,
        "unit": "score",
        "description": "Contrast ratio should be at least 90"
      },
      {
        "metric": "accessibility",
        "budget": 95,
        "unit": "score",
        "description": "Accessibility score should be at least 95"
      }
    ],
    "best-practices": [
      {
        "metric": "seo",
        "budget": 90,
        "unit": "score",
        "description": "SEO score should be at least 90"
      }
    ]
  },
  "targets": {
    "lighthouse": {
      "performance": 90,
      "accessibility": 95,
      "best-practices": 90,
      "seo": 90
    },
    "bundle": {
      "jsTotalSize": "500 KB",
      "jsGzipSize": "150 KB",
      "cssTotalSize": "100 KB",
      "htmlAverageSize": "50 KB"
    }
  }
}
