{
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "lint:calculators": "eslint myhugoapp/static/js/calculators/",
    "lint:tests": "eslint tests/",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,html,css}\"",
    "validate": "npm run lint && npm run format:check && npm test",
    "prepare": "husky",
    "minify": "node scripts/minify-calculators.js",
    "analyze:performance": "node scripts/analyze-bundle.js",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "performance:check": "node scripts/analyze-bundle.js",
    "optimize": "npm run minify && npm run performance:check",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "audit:dev": "npm audit --audit-level=moderate --only=dev",
    "check:updates": "npm outdated",
    "update:dependencies": "npm update",
    "security:check": "npm run audit && npm run check:updates",
    "build": "docker run --rm -v \"$(pwd)/myhugoapp:/src\" -w /src hugomods/hugo:exts hugo --minify --baseURL https://chemie-lernen.org"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,jsx,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@playwright/test": "^1.57.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.12.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "terser": "^5.44.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "myhugoapp/static/js/calculators/**/*.js",
      "myhugoapp/static/js/utils/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(three|three-orbitcontrols|three-js-camera)/)"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
