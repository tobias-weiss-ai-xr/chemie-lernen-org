al\">O</mi><msub><mpadded width=\"0px\"><mphantom><mi>X</mi></mphantom></mpadded><mpadded height=\"0px\"><mn>6</mn></mpadded></msub><mrow></mrow><mo>+</mo><mrow></mrow><mn>6</mn> <mi mathvariant=\"normal\">O</mi><msub><mpadded width=\"0px\"><mphantom><mi>X</mi></mphantom></mpadded><mpadded height=\"0px\"><mn>2</mn></mpadded></msub></mrow><annotation encoding=\"application/x-tex\">\\ce{6CO2 + 6H2O -&gt; C6H12O6 + 6O2}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height: 0.8333em; vertical-align: -0.15em;\"></span><span class=\"mord\"><span class=\"mord\">6</span><span class=\"mspace\" style=\"margin-right: 0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathrm\">CO</span></span><span class=\"mord\"><span class=\"mord\"><span class=\"mord rlap\"><span class=\"inner\"><span class=\"mord\" style=\"color: transparent;\"><span class=\"mord mathnormal\" style=\"margin-right: 0.0785em; color: transparent;\">X</span></span></span><span class=\"fix\"></span></span></span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\"><span class=\"\" style=\"top: -2.55em; margin-right: 0.05em;\"><span class=\"pstrut\" style=\"height: 2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\"><span class=\"mord mtight\"><span class=\"vlist-t\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height: 0em;\"><span class=\"\" style=\"top: -2.7em;\"><span class=\"pstrut\" style=\"height: 2.7em;\"></span><span class=\"\"><span class=\"mord mtight\"><span class=\"mord mtight\">2</span></span></span></span></span></span></span></span></span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height: 0.15em;\"><span class=\"\"></span></span></span></span></span></span><span class=\"mord\"></span><span class=\"mspace\" style=\"margin-right: 0.2222e