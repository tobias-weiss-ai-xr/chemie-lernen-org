  \n    "],"\n    \n\n    \n    \n  "],"\n"],"\n\n\n",["STYLE",{},"\n.breadcrumb {\n  background-color: transparent;\n  padding: 8px 0;\n  margin-bottom: 10px;\n  font-size: 0.9rem;\n}\n\n.breadcrumb-item + .breadcrumb-item::before {\n  content: \"›\";\n  color: #6c757d;\n}\n\n.breadcrumb-item a {\n  color: #007bff;\n  text-decoration: none;\n}\n\n.breadcrumb-item a:hover {\n  color: #0056b3;\n  text-decoration: underline;\n}\n\n.breadcrumb-item.active {\n  color: #6c757d;\n}\n\n \n@media (prefers-color-scheme: dark) {\n  .breadcrumb-item a {\n    color: #66b0ff;\n  }\n\n  .breadcrumb-item a:hover {\n    color: #3395ff;\n  }\n\n  .breadcrumb-item.active {\n    color: #adb5bd;\n  }\n}\n"],"\n\n      ",["DIV",{"class":"wrapper"},"\n        ",["MAIN",{"id":"main-content","role":"main"},"\n          \n\n\n\n\n\n\n",["DIV",{"class":"thema-container"},"\n\n  \n  ",["DIV",{"class":"thema-header"},"\n    ",["DIV",{"class":"row"},"\n      ",["DIV",{"class":"col-md-12"},"\n        \n        ",["DIV",{"class":"thema-icon"},"⚛️"],"\n        \n        ",["H1",{},"Aufbau der Materie"],"\n\n        \n        ",["DIV",{"class":"thema-metadata"},"\n          \n          ",["SPAN",{"class":"label label-difficulty label-grundlagen"},"\n            🌱 Grundlagen\n            \n          "],"\n          \n\n          \n          ",["SPAN",{"class":"label label-primary"},"🖱️ Enthält interaktive Elemente"],"\n          \n\n          \n          ",["SPAN",{"class":"label label-default"},"aufbau-materie"],"\n          \n        "],"\n      "],"\n    "],"\n\n    ",["HR",{"class":"featurette-divider"}],"\n  "],"\n\n  \n  ",["DIV",{"class":"thema-content-layout"},"\n    ",["DIV",{"class":"row"},"\n      \n      ",["DIV",{"class":"col-md-8"},"\n        ",["ARTICLE",{"class":"thema-content"},"\n          ",["H1",{"id":"aufbau-der-materie"},"Aufbau der Materie"],"\n",["P",{},"Entdecken Sie den faszinierenden mikroskopischen Aufbau unserer Welt! Alles, was wir sehen und berühren können, besteht aus unsichtbaren Teilchen, die auf faszinierende Weise angeordnet sind. Von den kleinsten Atomen bis zu komplexen Molekülen - verstehen Sie den Grundbaustein unseres Universums."],"\n",["H2",{"id":"lernziele"},"Lernziele"],"\n",["P",{},"Nach diesem Themenbereich können Sie:"],"\n",["UL",{},"\n",["LI",{},"Die Entwicklung der Atommodelle beschreiben"],"\n",["LI",{},"Aufbau und Eigenschaften von Elementarteilchen erklären"],"\n",["LI",{},"Das Periodensystem der Elemente lesen und interpretieren"],"\n",["LI",{},"Verschiedene chemische Bindungen unterscheiden"],"\n",["LI",{},"Die Bedeutung von Ionen für die Stoffeigenschaften verstehen"],"\n"],"\n",["H2",{"id":"was-ist-materie"},"Was ist Materie?"],"\n",["P",{},["STRONG",{},"Materie"]," ist alles, was Masse und Volumen besitzt. Sie besteht aus kleinsten Teilchen, den ",["STRONG",{},"Atomen"],". Atome können allein oder in Verbindung mit anderen Atomen ",["STRONG",{},"Moleküle"]," bilden."],"\n",["H3",{"id":"die-aggregatzustände-der-materie"},"Die Aggregatzustände der Materie"],"\n",["TABLE",{},"\n",["THEAD",{},"\n",["TR",{},"\n",["TH",{},"Aggregatzustand"],"\n",["TH",{},"Anordnung der Teilchen"],"\n",["TH",{},"Bewegung"],"\n",["TH",{},"Beispiel"],"\n"],"\n"],"\n",["TBODY",{},"\n",["TR",{},"\n",["TD",{},["STRONG",{},"fest"]],"\n",["TD",{},"Regelmäßig, dicht gepackt"],"\n",["TD",{},"Schwingen am Platz"],"\n",["TD",{},"Eis, Eisen"],"\n"],"\n",["TR",{},"\n",["TD",{},["STRONG",{},"flüssig"]],"\n",["TD",{},"Unregelmäßig, nah beieinander"],"\n",["TD",{},"Bewegen sich aneinander"],"\n",["TD",{},"Wasser, Quecksilber"],"\n"],"\n",["TR",{},"\n",["TD",{},["STRONG",{},"gasförmig"]],"\n",["TD",{},"Große Abstände, regellos"],"\n",["TD",{},"Schnell, frei beweglich"],"\n",["TD",{},"Sauerstoff, Wasserdampf"],"\n"],"\n"],"\n"],"\n",["H2",{"id":"die-elementarteilchen-des-atoms"},"Die Elementarteilchen des Atoms"],"\n",["P",{},"Atome bestehen aus drei wichtigsten Teilchen:"],"\n",["H3",{"id":"1-protonen-p"},"1. Protonen (p⁺)"],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Ladung:"]," +1 Elementarladung"],"\n",["LI",{},["STRONG",{},"Masse:"]," 1.0073 u (atomare Masseneinheit)"],"\n",["LI",{},["STRONG",{},"Ort:"]," Im Atomkern"],"\n",["LI",{},["STRONG",{},"Anzahl:"]," Bestimmt das Element (Ordnungszahl)"],"\n"],"\n",["H3",{"id":"2-neutronen-n"},"2. Neutronen (n⁰)"],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Ladung:"]," Neutral (keine Ladung)"],"\n",["LI",{},["STRONG",{},"Masse:"]," 1.0087 u"],"\n",["LI",{},["STRONG",{},"Ort:"]," Im Atomkern"],"\n",["LI",{},["STRONG",{},"Anzahl:"]," Variiert (Isotope)"],"\n"],"\n",["H3",{"id":"3-elektronen-e"},"3. Elektronen (e⁻)"],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Ladung:"]," -1 Elementarladung"],"\n",["LI",{},["STRONG",{},"Masse:"]," 0.00055 u (sehr leicht)"],"\n",["LI",{},["STRONG",{},"Ort:"]," In der Elektronenhülle um den Kern"],"\n",["LI",{},["STRONG",{},"Anzahl:"]," Gleich der Protonenzahl (bei neutralen Atomen)"],"\n"],"\n",["H3",{"id":"struktur-des-atoms"},"Struktur des Atoms"],"\n",["P",{},["IMG",{"__playwright_current_src__":"https://chemie-lernen.org/img/atom-struktur.png","src":"/img/atom-struktur.png","alt":"Struktur des Atoms"}]],"\n",["P",{},"Das Atom besteht aus einem kompakten Kern mit Protonen und Neutronen, umgeben von einer Elektronenhülle."],"\n",["P",{},["STRONG",{},"Wichtige Größen:"]],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Protonenzahl (Z):"]," Anzahl der Protonen = Ordnungszahl"],"\n",["LI",{},["STRONG",{},"Massenzahl (A):"]," Protonen + Neutronen"],"\n",["LI",{},["STRONG",{},"Elektronenzahl:"]," Bei neutralen Atomen = Protonenzahl"],"\n"],"\n",["P",{},["STRONG",{},"Beispiel: Kohlenstoff-12 (¹²C)"]],"\n",["UL",{},"\n",["LI",{},"Protonenzahl Z = 6"],"\n",["LI",{},"Neutronenzahl N = 6"],"\n",["LI",{},"Massenzahl A = 12"],"\n",["LI",{},"Elektronenzahl = 6"],"\n"],"\n",["H2",{"id":"die-entwicklung-der-atommodelle"},"Die Entwicklung der Atommodelle"],"\n",["H3",{"id":"1-daltons-atommodell-1803"},"1. Daltons Atommodell (1803)"],"\n",["P",{},"John Dalton stellte die Atomhypothese auf:"],"\n",["UL",{},"\n",["LI",{},"Materie besteht aus unteilbaren Teilchen (Atomen)"],"\n",["LI",{},"Atome eines Elements sind identisch"],"\n",["LI",{},"Atome verschiedener Elemente haben unterschiedliche Massen"],"\n",["LI",{},"Atome können sich verbinden, aber nicht verändert werden"],"\n"],"\n",["H3",{"id":"2-thomsons-atommodell-1904---rosinenkuchenmodell"},"2. Thomsons Atommodell (1904) - “Rosinenkuchenmodell”"],"\n",["P",{},"J.J. Thomson entdeckte das Elektron:"],"\n",["UL",{},"\n",["LI",{},"Positive Masse gleichmäßig verteilt (“Kuchenteig”)"],"\n",["LI",{},"Negative Elektronen eingebettet (“Rosinen”)"],"\n",["LI",{},"Atom ist elektrisch neutral"],"\n"],"\n",["H3",{"id":"3-rutherfords-atommodell-1911---kern-hülle-modell"},"3. Rutherfords Atommodell (1911) - “Kern-Hülle-Modell”"],"\n",["P",{},"Ernest Rutherford führte das berühmte Streuexperiment durch:"],"\n",["UL",{},"\n",["LI",{},"Positiver Kern im Zentrum (winzig, aber schwer)"],"\n",["LI",{},"Große leere Hülle mit Elektronen"],"\n",["LI",{},"Vergleich: Wie eine Fliege (Elektron) in einer Kathedrale (Atom)"],"\n"],"\n",["H3",{"id":"4-bohrsches-atommodell-1913"},"4. Bohrsches Atommodell (1913)"],"\n",["P",{},"Niels Bohr erweiterte das Modell:"],"\n",["UL",{},"\n",["LI",{},"Elektronen bewegen sich auf definierten Bahnen (Schalen)"],"\n",["LI",{},"Jede Schale hat eine bestimmte Energie"],"\n",["LI",{},"Elektronen können zwischen Schalen springen (Energieabgabe/ -aufnahme)"],"\n"],"\n",["P",{},["STRONG",{},"Bohrsche Postulate:"]],"\n",["OL",{},"\n",["LI",{},"Elektronen kreisen auf diskreten Bahnen um den Kern"],"\n",["LI",{},"Auf diesen Bahnen strahlen sie keine Energie ab"],"\n",["LI",{},"Energie wird nur bei Quantensprüngen abgegeben/absorbiert"],"\n"],"\n",["H3",{"id":"5-orbitalmodell-heute-gültig"},"5. Orbitalmodell (heute gültig)"],"\n",["P",{},"Das moderne quantenmechanische Modell:"],"\n",["UL",{},"\n",["LI",{},"Keine genauen Bahnen, sondern ",["STRONG",{},"Orbitale"]," (Aufenthaltswahrscheinlichkeiten)"],"\n",["LI",{},"Elektronenwolke um den Kern"],"\n",["LI",{},"Vier Quantenzahlen beschreiben den Zustand eines Elektrons"],"\n"],"\n",["H2",{"id":"das-periodensystem-der-elemente"},"Das Periodensystem der Elemente"],"\n",["H3",{"id":"aufbau-des-periodensystems"},"Aufbau des Periodensystems"],"\n",["P",{},"Das Periodensystem ordnet alle ",["STRONG",{},"118 bekannten Elemente"]," nach:"],"\n",["OL",{},"\n",["LI",{},["STRONG",{},"Ordnungszahl (Protonenzahl)"]," - von oben nach unten"],"\n",["LI",{},["STRONG",{},"Ähnlichen Eigenschaften"]," - in Gruppen (senkrecht)"],"\n"],"\n",["H3",{"id":"struktur"},"Struktur"],"\n",["P",{},["IMG",{"__playwright_current_src__":"https://chemie-lernen.org/img/pse-erklaerung.png","src":"/img/pse-erklaerung.png","alt":"Struktur des Periodensystems"}]],"\n",["P",{},["STRONG",{},"Legende:"]],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Hauptgruppe (A):"]," Gruppen 1-2 und 13-18"],"\n",["LI",{},["STRONG",{},"Nebengruppe (B):"]," Gruppen 3-12 (Übergangsmetalle)"],"\n",["LI",{},["STRONG",{},"Periode:"]," Zeilen (1-7)"],"\n",["LI",{},["STRONG",{},"Gruppe:"]," Spalten"],"\n"],"\n",["H3",{"id":"wichtige-gruppen"},"Wichtige Gruppen"],"\n",["UL",{},"\n",["LI",{},"\n",["P",{},["STRONG",{},"Hauptgruppen (1-2, 13-18):"]],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Alkalimetalle (1):"]," Li, Na, K, Rb, Cs, Fr - sehr reaktiv"],"\n",["LI",{},["STRONG",{},"Erdalkalimetalle (2):"]," Be, Mg, Ca, Sr, Ba, Ra - reaktiv"],"\n",["LI",{},["STRONG",{},"Halogene (17):"]," F, Cl, Br, I, At - sehr reaktiv, nichtmetalle"],"\n",["LI",{},["STRONG",{},"Edelgase (18):"]," He, Ne, Ar, Kr, Xe, Rn - sehr reaktionsträge"],"\n"],"\n"],"\n",["LI",{},"\n",["P",{},["STRONG",{},"Nebengruppen (3-12):"]," Übergangsmetalle (z.B. Fe, Cu, Zn, Au)"],"\n"],"\n"],"\n",["H3",{"id":"perioden-zeilen"},"Perioden (Zeilen)"],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Periode 1:"]," 2 Elemente (H, He)"],"\n",["LI",{},["STRONG",{},"Periode 2+3:"]," 8 Elemente"],"\n",["LI",{},["STRONG",{},"Periode 4+5:"]," 18 Elemente"],"\n",["LI",{},["STRONG",{},"Periode 6+7:"]," 32 Elemente (inkl. Lanthanoide/Actinoide)"],"\n"],"\n",["H3",{"id":"informationen-im-periodensystem"},"Informationen im Periodensystem"],"\n",["P",{},"Für jedes Element können Sie ablesen:"],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Ordnungszahl:"]," Anzahl der Protonen"],"\n",["LI",{},["STRONG",{},"Symbol:"]," Abkürzung (z.B. C für Kohlenstoff)"],"\n",["LI",{},["STRONG",{},"Atommasse:"]," Durchschnittsmasse aller Isotope"],"\n",["LI",{},["STRONG",{},"Elektronenkonfiguration:"]," Verteilung der Elektronen"],"\n"],"\n",["P",{},"🧪 ",["STRONG",{},"Interaktiv:"]," Erkunden Sie das ",["STRONG",{},["A",{"href":"/perioden-system-der-elemente/"},"Periodensystem 3D"]]," und erfahren Sie mehr über jedes Element!"],"\n",["H2",{"id":"chemische-bindungen"},"Chemische Bindungen"],"\n",["H3",{"id":"ionenbindung-elektrovalenz"},"Ionenbindung (Elektrovalenz)"],"\n",["P",{},"Bei der Ionenbindung werden Elektronen ",["STRONG",{},"vollständig übertragen"],"."],"\n",["P",{},["STRONG",{},"Vorgang:"]],"\n",["OL",{},"\n",["LI",{},"Metall gibt Elektronen ab → ",["STRONG",{},"Kation"]," (positiv geladen)"],"\n",["LI",{},"Nichtmetall nimmt Elektronen auf → ",["STRONG",{},"Anion"]," (negativ geladen)"],"\n",["LI",{},"Elektrostatische Anziehung zwischen Ionen"],"\n"],"\n",["P",{},["STRONG",{},"Beispiel: Natriumchlorid (Kochsalz)"]],"\n",["P",{},["SPAN",{},["SPAN",{"class":"katex-display"},["SPAN",{"class":"katex"},["SPAN",{"class":"katex-mathml"},["math",{"xmlns":"http://www.w3.org/1998/Math/MathML","display":"block"},["semantics",{},["mrow",{},["mrow",{},["mrow",{},["mi",{"mathvariant":"normal"},"N"],["mi",{"mathvariant":"normal"},"a"]],["mover",{},["mo",{"stretchy":"true","minsize":"3.0em"},"→"],["mpadded",{"width":"+0.6em","lspace":"0.3em"},["mrow"]]],["mrow",{},["mi",{"mathvariant":"normal"},"N"],["mi",{"mathvariant":"normal"},"a"]],["msup",{},["mpadded",{"width":"0px"},["mphantom",{},["mi",{},"X