\n  }\n}\n"],"\n\n\n",["STYLE",{},"\n \n.themenbereiche-container {\n  margin-top: 20px;\n  margin-bottom: 40px;\n}\n\n \n.filter-controls {\n  background-color: #f8f9fa;\n  padding: 20px;\n  border-radius: 8px;\n  margin-bottom: 20px;\n}\n\n.filter-group {\n  margin-bottom: 15px;\n}\n\n.filter-group:last-child {\n  margin-bottom: 0;\n}\n\n.filter-group label {\n  font-weight: 600;\n  margin-right: 10px;\n  color: #495057;\n}\n\n.btn-group .btn {\n  border-radius: 4px;\n  margin-right: 5px;\n  transition: all 0.2s;\n}\n\n.btn-filter.active,\n.btn-filter:hover,\n.btn-type-filter.active,\n.btn-type-filter:hover {\n  transform: scale(1.05);\n}\n\n.search-group input {\n  border-radius: 20px;\n  padding-left: 15px;\n  border: 1px solid #ced4da;\n}\n\n.search-group input:focus {\n  border-color: #007bff;\n  box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);\n}\n\n \n.difficulty-grundlagen {\n  border-left: 5px solid #28a745 !important;\n}\n\n.difficulty-mittelstufe {\n  border-left: 5px solid #ffc107 !important;\n}\n\n.difficulty-fortgeschritten {\n  border-left: 5px solid #dc3545 !important;\n}\n\n.difficulty-alle {\n  border-left: 5px solid #6c757d !important;\n}\n\n \n.card {\n  margin-bottom: 20px;\n  transition: all 0.3s ease;\n}\n\n.topic-card {\n  opacity: 1;\n  transform: scale(1);\n  transition: all 0.3s ease;\n}\n\n.topic-card.hidden {\n  display: none;\n}\n\n.card .panel {\n  height: 100%;\n  transition: transform 0.2s, box-shadow 0.2s;\n  border-radius: 8px;\n}\n\n.card .panel:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 6px 16px rgba(0,0,0,0.15);\n}\n\n.index-anchor {\n  text-decoration: none;\n  color: inherit;\n  display: block;\n}\n\n.panel-body h3.panel-title {\n  font-size: 1.1rem;\n  margin: 0;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.interactive-badge {\n  font-size: 1.2rem;\n  animation: pulse 2s infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.6; }\n}\n\n.panel-f